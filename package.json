{
  "name": "dolphinforge",
  "version": "0.1.0-alpha.2",
  "description": "DolphinForge — быстрое пересоздание профилей DolphinAnty с сохранением настроек клиента",
  "main": "./out/main/index.js",
  "author": "Agency internal tool",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "dist": "electron-vite build && electron-builder --win --x64"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "google-auth-library": "^9.15.0",
    "googleapis": "^144.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.39",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  },
  "build": {
    "appId": "com.f4rm4ceft.dolphinforge",
    "productName": "DolphinForge",
    "files": ["out/**/*", "package.json"],
    "extraResources": ["user_agents_mac_devices.csv"],
    "win": {
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
